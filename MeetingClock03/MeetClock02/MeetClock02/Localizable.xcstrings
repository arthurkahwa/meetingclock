    "Hourly rates bill per hour. Daily rates are divided by 8 to get the hourly equivalent." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تُحتسب الأسعار بالساعة لكل ساعة. تُقسم الأسعار اليومية على 8 للحصول على المعادل بالساعة."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ঘণ্টা প্রতি হার প্রতি ঘণ্টায় বিল করা হয়। দৈনিক হারকে ঘণ্টা সমতুল্য পেতে 8 দিয়ে ভাগ করা হয়।"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Las tarifas por hora se cobran por hora. Las tarifas diarias se dividen entre 8 para obtener el equivalente por hora."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Les taux horaires sont facturés par heure. Les taux journaliers sont divisés par 8 pour obtenir l'équivalent horaire."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "प्रति घंटा दरें प्रति घंटे बिल की जाती हैं। दैनिक दरों को प्रति घंटा समकक्ष प्राप्त करने के लिए 8 से विभाजित किया जाता है।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "時給レートは1時間ごとに請求されます。日給レートは8で割って時給換算します。"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "As tarifas por hora são cobradas por hora. As tarifas diárias são divididas por 8 para obter o equivalente por hora."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Почасовые ставки оплачиваются за каждый час. Дневные ставки делятся на 8 для получения почасового эквивалента."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "按小时计费。日薪除以8得到每小时等值。"
          }
        }
      }
    },
