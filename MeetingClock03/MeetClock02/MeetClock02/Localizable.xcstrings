    "Resets the timer to zero and starts again, keeping all participants" : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "يعيد ضبط المؤقت إلى الصفر ويبدأ من جديد، مع الاحتفاظ بجميع المشاركين"
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "টাইমার শূন্যে রিসেট করে এবং সমস্ত অংশগ্রহণকারী রেখে আবার শুরু করে"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Reinicia el temporizador a cero y comienza de nuevo, manteniendo todos los participantes"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Remet le minuteur à zéro et recommence, en conservant tous les participants"
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "टाइमर को शून्य पर रीसेट करता है और सभी प्रतिभागियों को बनाए रखते हुए फिर से शुरू करता है"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "タイマーをゼロにリセットしてすべての参加者を維持したまま再開します"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Redefine o temporizador para zero e começa novamente, mantendo todos os participantes"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Сбрасывает таймер на ноль и начинает заново, сохраняя всех участников"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "将计时器重置为零并重新开始，保留所有参与者"
          }
        }
      }
    },
