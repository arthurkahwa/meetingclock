    "No participants added yet. Tap Add Participant to add people or resources." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "لم يتم إضافة مشاركين بعد. اضغط على «إضافة مشارك» لإضافة أشخاص أو موارد."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "এখনো কোনো অংশগ্রহণকারী যোগ করা হয়নি। মানুষ বা রিসোর্স যোগ করতে অংশগ্রহণকারী যোগ করুন-এ ট্যাপ করুন।"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aún no se han añadido participantes. Toca Añadir participante para agregar personas o recursos."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aucun participant ajouté pour l'instant. Appuyez sur Ajouter un participant pour ajouter des personnes ou des ressources."
