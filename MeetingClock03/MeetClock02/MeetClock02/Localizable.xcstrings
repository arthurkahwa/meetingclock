    "Warning: meetings use different currencies. Costs are shown in each meeting's own currency and are not directly comparable." : {
      "localizations" : {
        "ar" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "تحذير: تستخدم الاجتماعات عملات مختلفة. تُعرض التكاليف بعملة كل اجتماع وليست قابلة للمقارنة المباشرة."
          }
        },
        "bn" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "সতর্কতা: মিটিংগুলো বিভিন্ন মুদ্রা ব্যবহার করে। খরচ প্রতিটি মিটিংয়ের নিজস্ব মুদ্রায় দেখানো হয়েছে এবং সরাসরি তুলনাযোগ্য নয়।"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Advertencia: las reuniones usan diferentes monedas. Los costos se muestran en la moneda propia de cada reunión y no son directamente comparables."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Avertissement : les réunions utilisent des devises différentes. Les coûts sont affichés dans la devise propre à chaque réunion et ne sont pas directement comparables."
          }
        },
        "hi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "चेतावनी: मीटिंग अलग-अलग मुद्राओं का उपयोग करती हैं। लागत प्रत्येक मीटिंग की अपनी मुद्रा में दिखाई जाती है और सीधे तुलनीय नहीं है।"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "警告：会議で異なる通貨が使用されています。コストは各会議固有の通貨で表示されており、直接比較することはできません。"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Aviso: as reuniões usam moedas diferentes. Os custos são mostrados na moeda própria de cada reunião e não são diretamente comparáveis."
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Предупреждение: встречи используют разные валюты. Стоимость отображается в валюте каждой встречи и не поддаётся прямому сравнению."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "警告：会议使用不同的货币。费用以每次会议各自的货币显示，不可直接比较。"
          }
        }
      }
    }
  },
  "version" : "1.1"
}